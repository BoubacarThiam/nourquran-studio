generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Project {
  id          String   @id @default(cuid())
  name        String
  config      String   // JSON serialisé de EditorConfig
  thumbnail   String?  // chemin vers une miniature
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  exports     Export[]
}

model Export {
  id          String       @id @default(cuid())
  projectId   String
  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  // status: "pending" | "rendering" | "done" | "failed"
  status      String   @default("pending")
  progress    Int      @default(0)
  outputPath  String?
  errorMsg    String?
  format      String   @default("mp4")
  resolution  String   @default("1080p")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Paramètres globaux de l'application (clés API, etc.)
model AppSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model CachedBackground {
  id          String   @id @default(cuid())
  pexelsId    String   @unique
  localPath   String
  url         String
  // type: "video" | "image"
  type        String
  query       String
  createdAt   DateTime @default(now())
}
